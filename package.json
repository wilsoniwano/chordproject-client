{
    "name": "chordproject-client",
    "version": "1.0.0",
    "description": "A web client for the ChordProject",
    "keywords": [
        "chordpro",
        "angular",
        "firebase",
        "chordproject"
    ],
    "homepage": "https://chordproject.com",
    "private": false,
    "scripts": {
        "ng": "ng",
        "start": "ng serve",
        "build": "ng build",
        "watch": "ng build --watch --configuration development",
        "release": "npm run build && firebase deploy",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "e2e": "playwright test",
        "e2e:ui": "playwright test --ui"
    },
    "dependencies": {
        "@angular/animations": "^19.2.19",
        "@angular/cdk": "^19.2.19",
        "@angular/common": "^19.2.19",
        "@angular/compiler": "^19.2.19",
        "@angular/core": "^19.2.19",
        "@angular/fire": "^19.1.0",
        "@angular/forms": "^19.2.19",
        "@angular/material": "^19.2.19",
        "@angular/platform-browser": "^19.2.19",
        "@angular/platform-browser-dynamic": "^19.2.19",
        "@angular/router": "^19.2.19",
        "@jsverse/transloco": "7.5.1",
        "angular-split": "^19.0.0",
        "chordproject-editor": "^0.1.11",
        "chordproject-parser": "^0.2.14",
        "crypto-js": "4.2.0",
        "firebase": "^11.6.0",
        "highlight.js": "11.11.1",
        "lodash-es": "^4.17.23",
        "ngx-quill": "27.0.0",
        "perfect-scrollbar": "1.5.6",
        "quill": "2.0.3",
        "rxjs": "7.8.1",
        "tslib": "2.8.1",
        "zone.js": "0.15.0"
    },
    "devDependencies": {
        "@angular-devkit/build-angular": "^19.2.22",
        "@angular/cli": "^19.2.22",
        "@angular/compiler-cli": "^19.2.19",
        "@axe-core/playwright": "^4.10.2",
        "@playwright/test": "^1.52.0",
        "@tailwindcss/typography": "0.5.15",
        "@types/chroma-js": "2.4.5",
        "@types/crypto-js": "4.2.2",
        "@types/highlight.js": "10.1.0",
        "@types/lodash": "4.17.13",
        "@types/lodash-es": "4.17.12",
        "@vitest/coverage-v8": "^3.2.4",
        "autoprefixer": "10.4.20",
        "chroma-js": "2.4.2",
        "jsdom": "^26.1.0",
        "lodash": "^4.17.23",
        "postcss": "8.4.49",
        "prettier": "3.4.2",
        "prettier-plugin-organize-imports": "4.1.0",
        "prettier-plugin-tailwindcss": "0.6.9",
        "tailwindcss": "3.4.17",
        "typescript": "5.6.3",
        "vitest": "^3.2.4"
    }
}
